{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "backend/data/**/*",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]?path=$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/uploads/file/$1"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/politicians",
      "destination": "/index.html"
    },
    {
      "source": "/parties",
      "destination": "/index.html"
    },
    {
      "source": "/states",
      "destination": "/index.html"
    },
    {
      "source": "/legal",
      "destination": "/index.html"
    },
    {
      "source": "/news",
      "destination": "/index.html"
    },
    {
      "source": "/approvals",
      "destination": "/index.html"
    },
    {
      "source": "/watchlist",
      "destination": "/index.html"
    },
    {
      "source": "/compare",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    }
  ]
}

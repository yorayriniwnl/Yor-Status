PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_minimum_64_chars
JWT_EXPIRES_IN=7d
ADMIN_SETUP_KEY=your_admin_setup_key_here

# Anthropic (AI Chat)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: SMTP for email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@yorstatus.in

# Optional: Upload path (default: ./uploads)
UPLOAD_DIR=./uploads
MAX_FILE_MB=10
